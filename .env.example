# Debt Angel — environment variables
# Copy to .env.local and fill in before running /apply submissions.

# Supabase (required for /apply — anonymous auth + RLS-backed persistence)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Enable anonymous sign-in in Supabase Dashboard → Authentication → Providers → Anonymous

# Scheduling link shown on the thank-you screen (e.g. Cal.com)
NEXT_PUBLIC_SCHEDULING_URL=https://cal.com/debt-angel/intro

# Public site URL — used for magic-link redirects (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://debtangel.t3kdesigns.app

# Add these redirect URLs in Supabase → Authentication → URL Configuration:
# - https://debtangel.t3kdesigns.app/auth/callback
# - http://localhost:3000/auth/callback
